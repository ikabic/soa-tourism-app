{
  "title": "Host and Container Monitoring",
  "uid": "host_container_monitoring",
  "schemaVersion": 42,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "hideControls": false,
  "panels": [
    {
      "type": "gauge",
      "title": "Host CPU Usage",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[1m])) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 80}]}
        }
      }
    },
    {
      "type": "gauge",
      "title": "Host RAM Usage",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}) / node_memory_MemTotal_bytes{job=\"node-exporter\"}) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 80}]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Host Filesystem Usage",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * (sum(node_filesystem_size_bytes{job=\"node-exporter\",fstype!~\"tmpfs|overlay|squashfs\"}) - sum(node_filesystem_free_bytes{job=\"node-exporter\",fstype!~\"tmpfs|overlay|squashfs\"})) / sum(node_filesystem_size_bytes{job=\"node-exporter\",fstype!~\"tmpfs|overlay|squashfs\"})",
          "legendFormat": "host filesystem",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent"}
      }
    },
    {
      "type": "timeseries",
      "title": "Host Network Traffic",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total{job=\"node-exporter\"}[1m]))",
          "legendFormat": "receive {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by(instance) (rate(node_network_transmit_bytes_total{job=\"node-exporter\"}[1m]))",
          "legendFormat": "transmit {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "Bps"}
      }
    },
    {
      "type": "gauge",
      "title": "Container CPU Usage",
      "gridPos": {"x": 0, "y": 16, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\"}[1m])) / count(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 80}]}
        }
      }
    },
    {
      "type": "gauge",
      "title": "Container RAM Usage",
      "gridPos": {"x": 6, "y": 16, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(name) (container_memory_working_set_bytes{job=\"cadvisor\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 8589934592}]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Container Filesystem Usage",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "container_fs_usage_bytes{job=\"cadvisor\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes"}
      }
    },
    {
      "type": "timeseries",
      "title": "Container Network Traffic",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by(name) (rate(container_network_receive_bytes_total{job=\"cadvisor\"}[1m]))",
          "legendFormat": "receive {{name}}",
          "refId": "A"
        },
        {
          "expr": "sum by(name) (rate(container_network_transmit_bytes_total{job=\"cadvisor\"}[1m]))",
          "legendFormat": "transmit {{name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "Bps"}
      }
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "15s",
  "templating": {"list": []},
  "annotations": {"list": []},
  "version": 1
}
